should work:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: lldap
        app.kubernetes.io/version: 0.4.0
        helm.sh/chart: lldap-0.4.0
      name: lldap
    spec:
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/instance: RELEASE-NAME
          app.kubernetes.io/name: lldap
      template:
        metadata:
          labels:
            app.kubernetes.io/instance: RELEASE-NAME
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/name: lldap
            app.kubernetes.io/version: 0.4.0
            helm.sh/chart: lldap-0.4.0
        spec:
          containers:
            - env:
                - name: NEXTAUTH_SECRET
                  valueFrom:
                    secretKeyRef:
                      key: NEXTAUTH_SECRET
                      name: lldap-secret
                - name: LLDAP_JWT_SECRET
                  valueFrom:
                    secretKeyRef:
                      key: LLDAP_JWT_SECRET
                      name: lldap-secret
                - name: LLDAP_LDAP_USER_PASS
                  valueFrom:
                    secretKeyRef:
                      key: LLDAP_LDAP_USER_PASS
                      name: lldap-secret
              envFrom:
                - configMapRef:
                    name: RELEASE-NAME-config
              image: lldap/lldap
              livenessProbe:
                httpGet:
                  path: /
                  port: webui
              name: lldap
              ports:
                - containerPort: 3890
                  name: ldap
                  protocol: TCP
                - containerPort: 6360
                  name: ldaps
                  protocol: TCP
                - containerPort: 17170
                  name: webui
                  protocol: TCP
              readinessProbe:
                httpGet:
                  path: /
                  port: webui
              volumeMounts:
                - mountPath: /data
                  name: data
          volumes:
            - name: data
              persistentVolumeClaim:
                claimName: lldap-data
