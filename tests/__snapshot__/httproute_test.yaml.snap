should work:
  1: |
    apiVersion: gateway.networking.k8s.io/v1
    kind: HTTPRoute
    metadata:
      name: RELEASE-NAME-tls-redirect
    spec:
      hostnames:
        - ldap.breeze-blocks.net
      parentRefs:
        - name: RELEASE-NAME
          sectionName: http
      rules:
        - filters:
            - requestRedirect:
                scheme: https
                statusCode: 301
              type: RequestRedirect
  2: |
    apiVersion: gateway.networking.k8s.io/v1
    kind: HTTPRoute
    metadata:
      name: RELEASE-NAME
    spec:
      hostnames:
        - ldap.breeze-blocks.net
      parentRefs:
        - name: RELEASE-NAME
          sectionName: https
      rules:
        - backendRefs:
            - name: RELEASE-NAME
              port: 17170
              weight: 1
          matches:
            - path:
                type: PathPrefix
                value: /
