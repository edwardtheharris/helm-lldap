should work:
  1: |
    apiVersion: gateway.networking.k8s.io/v1
    kind: Gateway
    metadata:
      annotations:
        cert-manager.io/cluster-issuer: thw-svc-int-ca
        cert-manager.io/common-name: ldap.breeze-blocks.net
        cert-manager.io/usages: key agreement,digital signature,server auth
      name: RELEASE-NAME
    spec:
      gatewayClassName: eg
      listeners:
        - allowedRoutes:
            namespaces:
              from: All
          hostname: ldap.breeze-blocks.net
          name: http
          port: 80
          protocol: HTTP
        - allowedRoutes:
            namespaces:
              from: All
          hostname: ldap.breeze-blocks.net
          name: https
          port: 443
          protocol: HTTPS
          tls:
            certificateRefs:
              - name: RELEASE-NAME-tls
            mode: Terminate
  2: |
    apiVersion: gateway.networking.k8s.io/v1
    kind: Gateway
    metadata:
      annotations:
        cert-manager.io/cluster-issuer: thw-svc-int-ca
        cert-manager.io/common-name: ldaps.breeze-blocks.net
        cert-manager.io/usages: key agreement,digital signature,server auth
      name: RELEASE-NAME-ldap
    spec:
      gatewayClassName: eg
      listeners:
        - name: RELEASE-NAME-ldaps
          port: 6360
          protocol: TLS
          tls:
            certificateRefs:
              - name: lldap-ldaps-tls
            mode: Terminate
        - name: RELEASE-NAME-ldap
          port: 3890
          protocol: TCP
